# Openstartup monorepo environment

# SDK and API
OPENSTARTUP_API_URL=https://api.openstartup.network

# Privy (auth)
PRIVY_PROJECT_ID=your-privy-project-id
PRIVY_SECRET=your-privy-secret

# PostgreSQL
DATABASE_URL=postgresql://user:pass@localhost:5432/openstartup

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com

# App
NODE_ENV=development
PORT=3000
